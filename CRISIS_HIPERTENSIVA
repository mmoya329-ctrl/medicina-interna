}
.quiz-opt:hover { background: rgba(255,255,255,0.08); border-color: var(–gold); }
.quiz-opt.correct { background: rgba(107,168,150,0.2); border-color: var(–sage-light); color: #A8DACC; }
.quiz-opt.wrong { background: rgba(192,41,58,0.2); border-color: var(–crimson-light); color: #F09BA6; }
