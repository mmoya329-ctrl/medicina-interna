box-shadow: 0 1px 6px var(–shadow);
}
.clinical-organ h4 {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.75rem;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–crimson);
margin-bottom: 0.55rem;
padding-bottom: 0.35rem;
border-bottom: 1px solid rgba(192,41,58,0.15);
}
.clinical-organ ul { list-style: none; }
.clinical-organ li {
font-size: 0.87rem;
padding: 0.18rem 0;
color: var(–text-body);
display: flex;
gap: 0.5rem;
align-items: flex-start;
}
.clinical-organ li::before {
content: ‘·’;
color: var(–crimson);
font-weight: 900;
flex-shrink: 0;
}

/* ─── QUIZ ─── */
.quiz-section {
