<title>Crisis Hipertensiva — Medicina Interna</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --crimson: #C0293A;
    --crimson-dark: #8B1A25;
    --crimson-light: #E84A5F;
    --ink: #1A1118;
    --parchment: #FAF7F2;
    --warm-white: #FFF9F5;
    --gold: #C9963A;
    --gold-light: #F0C96B;
    --slate: #2C3E50;
    --slate-mid: #4A6278;
    --slate-light: #8DA8BE;
    --sage: #3D6B5E;
    --sage-light: #6BA896;
    --amber: #D4721A;
    --text-body: #2D1F2B;
    --text-muted: #6B5A69;
    --border: #DDD5D8;
    --shadow: rgba(26,17,24,0.12);
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: ‘Source Serif 4’, Georgia, serif;
background: var(–parchment);
color: var(–text-body);
line-height: 1.75;
font-size: 15.5px;
}

/* ─── HEADER ─── */
header {
background: var(–ink);
color: white;
padding: 3rem 2rem 2.5rem;
position: relative;
overflow: hidden;
}
header::before {
content: ‘’;
position: absolute; inset: 0;
background: repeating-linear-gradient(
45deg,
transparent,
transparent 40px,
rgba(192,41,58,0.07) 40px,
rgba(192,41,58,0.07) 41px
);
}
header::after {
content: ‘’;
position: absolute;
bottom: 0; left: 0; right: 0;
height: 4px;
background: linear-gradient(90deg, var(–crimson), var(–gold), var(–crimson));
}
.header-inner {
max-width: 900px;
margin: 0 auto;
position: relative;
z-index: 1;
}
.header-tag {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.72rem;
letter-spacing: 0.18em;
color: var(–crimson-light);
text-transform: uppercase;
margin-bottom: 0.8rem;
}
header h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2rem, 5vw, 3.2rem);
font-weight: 900;
line-height: 1.1;
margin-bottom: 0.6rem;
}
header h1 span { color: var(–crimson-light); }
.header-sub {
font-size: 0.92rem;
color: rgba(255,255,255,0.55);
font-style: italic;
letter-spacing: 0.04em;
}

/* ─── LAYOUT ─── */
main {
max-width: 900px;
margin: 0 auto;
padding: 2.5rem 1.5rem 4rem;
}

/* ─── NAVIGATION PILLS ─── */
.nav-pills {
display: flex;
flex-wrap: wrap;
gap: 0.5rem;
margin-bottom: 2.5rem;
padding: 1.2rem;
background: white;
border-radius: 12px;
border: 1px solid var(–border);
box-shadow: 0 2px 12px var(–shadow);
}
.nav-pill {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.72rem;
letter-spacing: 0.06em;
padding: 0.35rem 0.85rem;
border-radius: 20px;
border: 1.5px solid var(–crimson);
color: var(–crimson-dark);
text-decoration: none;
background: transparent;
cursor: pointer;
transition: all 0.2s;
white-space: nowrap;
}
.nav-pill:hover {
background: var(–crimson);
color: white;
}

/* ─── SECTIONS ─── */
section {
margin-bottom: 2.8rem;
scroll-margin-top: 1.5rem;
}
.section-header {
display: flex;
align-items: center;
gap: 1rem;
margin-bottom: 1.2rem;
padding-bottom: 0.6rem;
border-bottom: 2px solid var(–crimson);
}
.section-number {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.75rem;
color: var(–crimson);
background: rgba(192,41,58,0.08);
padding: 0.15rem 0.5rem;
border-radius: 4px;
letter-spacing: 0.08em;
white-space: nowrap;
}
.section-header h2 {
font-family: ‘Playfair Display’, serif;
font-size: 1.35rem;
font-weight: 700;
color: var(–ink);
}

/* ─── COMPARISON TABLE (urgencia vs emergencia) ─── */
.compare-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 1.2rem;
margin: 1.2rem 0;
}
.compare-card {
border-radius: 10px;
overflow: hidden;
border: 1.5px solid;
box-shadow: 0 4px 16px var(–shadow);
}
.compare-card.urgencia { border-color: var(–amber); }
.compare-card.emergencia { border-color: var(–crimson); }
.compare-card-head {
padding: 0.8rem 1.2rem;
display: flex;
align-items: center;
gap: 0.6rem;
}
.urgencia .compare-card-head { background: var(–amber); }
.emergencia .compare-card-head { background: var(–crimson); }
.compare-card-head h3 {
font-family: ‘Playfair Display’, serif;
font-size: 1.05rem;
color: white;
font-weight: 700;
}
.compare-card-body {
padding: 1rem 1.2rem;
background: white;
}
.compare-card-body p { font-size: 0.93rem; margin-bottom: 0.5rem; }
.compare-card-body strong { color: var(–ink); }

/* ─── REGULAR TABLE ─── */
.data-table {
width: 100%;
border-collapse: collapse;
font-size: 0.9rem;
box-shadow: 0 2px 12px var(–shadow);
border-radius: 10px;
overflow: hidden;
}
.data-table th {
background: var(–ink);
color: white;
padding: 0.7rem 1rem;
text-align: left;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.75rem;
letter-spacing: 0.07em;
font-weight: 600;
}
.data-table td {
padding: 0.65rem 1rem;
border-bottom: 1px solid var(–border);
vertical-align: top;
}
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:nth-child(even) td { background: rgba(250,247,242,0.6); }
.data-table tr:hover td { background: rgba(192,41,58,0.04); }

/* ─── DRUG CARD ─── */
.drug-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
gap: 1rem;
margin-top: 1rem;
}
.drug-card {
background: white;
border-radius: 10px;
border: 1.5px solid var(–border);
overflow: hidden;
box-shadow: 0 2px 10px var(–shadow);
transition: transform 0.2s, box-shadow 0.2s;
}
.drug-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px var(–shadow); }
.drug-card-head {
padding: 0.65rem 1rem;
display: flex;
align-items: center;
justify-content: space-between;
}
.drug-card-head h4 {
font-family: ‘Playfair Display’, serif;
font-size: 0.98rem;
font-weight: 700;
color: white;
}
.drug-class-badge {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.65rem;
background: rgba(255,255,255,0.2);
color: white;
padding: 0.15rem 0.45rem;
border-radius: 10px;
letter-spacing: 0.06em;
}
.iv { background: var(–crimson-dark); }
.oral-sublingual { background: var(–sage); }
.iv-mixed { background: var(–slate); }
.drug-card-body {
padding: 0.9rem 1rem;
font-size: 0.85rem;
}
.drug-row {
display: flex;
gap: 0.4rem;
margin-bottom: 0.35rem;
align-items: flex-start;
}
.drug-label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.7rem;
color: var(–text-muted);
min-width: 68px;
letter-spacing: 0.04em;
padding-top: 0.12rem;
flex-shrink: 0;
}
.drug-value { color: var(–text-body); line-height: 1.5; }
.drug-alert {
margin-top: 0.6rem;
padding: 0.45rem 0.7rem;
border-radius: 6px;
font-size: 0.8rem;
display: flex;
gap: 0.4rem;
align-items: flex-start;
}
.drug-alert.warn { background: #FFF3CD; border-left: 3px solid var(–gold); color: #7A5500; }
.drug-alert.danger { background: #FDECEA; border-left: 3px solid var(–crimson); color: #8B1A25; }
.drug-alert.info { background: #E8F4FD; border-left: 3px solid #2980B9; color: #1A5276; }

/* ─── INFO BOXES ─── */
.info-box {
border-radius: 8px;
padding: 1rem 1.2rem;
margin: 1rem 0;
display: flex;
gap: 0.75rem;
font-size: 0.9rem;
line-height: 1.6;
}
.info-box .icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
.info-box.key { background: rgba(192,41,58,0.07); border-left: 4px solid var(–crimson); }
.info-box.tip { background: rgba(61,107,94,0.08); border-left: 4px solid var(–sage); }
.info-box.warn { background: rgba(212,114,26,0.08); border-left: 4px solid var(–amber); }
.info-box.colombia { background: rgba(201,150,58,0.1); border-left: 4px solid var(–gold); }

/* ─── FISIOPATOLOGIA ─── */
.fisio-flow {
display: flex;
flex-direction: column;
gap: 0;
margin: 1rem 0;
}
.fisio-step {
display: flex;
gap: 1rem;
align-items: flex-start;
}
.fisio-line {
display: flex;
flex-direction: column;
align-items: center;
flex-shrink: 0;
}
.fisio-dot {
width: 36px; height: 36px;
border-radius: 50%;
background: var(–crimson);
color: white;
display: flex;
align-items: center;
justify-content: center;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.8rem;
font-weight: 600;
flex-shrink: 0;
box-shadow: 0 2px 8px rgba(192,41,58,0.35);
}
.fisio-connector {
width: 2px;
height: 28px;
background: linear-gradient(to bottom, var(–crimson), var(–crimson-light));
opacity: 0.3;
}
.fisio-content {
flex: 1;
padding: 0.4rem 0 1rem;
}
.fisio-content h4 {
font-family: ‘Playfair Display’, serif;
font-size: 0.95rem;
font-weight: 700;
color: var(–ink);
margin-bottom: 0.25rem;
}
.fisio-content p { font-size: 0.88rem; color: var(–text-muted); }

/* ─── CLINICAL PRESENTATION LIST ─── */
.clinical-cols {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 1.2rem;
margin: 1rem 0;
